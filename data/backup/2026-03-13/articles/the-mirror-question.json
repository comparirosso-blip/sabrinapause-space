        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The work here takes several forms: spatial field research, books written in dialogue with AI, conversations about what systems reveal about the people who built them. Each piece exists in two layers simultaneously — one for human readers, one for machines. That double structure is not a technical choice. It is a position: if AI is a mirror, then the container holding this investigation should be honest to machines as well.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "The work here takes several forms: spatial field research, books written in dialogue with AI, conversations about what systems reveal about the people who built them. Each piece exists in two layers simultaneously — one for human readers, one for machines. That double structure is not a technical choice. It is a position: if AI is a mirror, then the container holding this investigation should be honest to machines as well.",
              "href": null
            }
          ],
          "color": "default"
        },
