        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "I came to this work believing AI would make me capable of everything. I was wrong, and I'm glad I was wrong.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "I came to this work believing AI would make me capable of everything. I was wrong, and I'm glad I was wrong.",
              "href": null
            }
          ],
          "color": "default"
        },
        "archived": false
      },
      {
        "object": "block",
        "id": "32018eed-3014-805e-9d03-c28075604bbf",
        "parent": {
