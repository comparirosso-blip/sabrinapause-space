        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The difference is speed. Scale. And the fact that it is extraordinarily good at agreeing with you — which makes it very difficult to locate the boundary between ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
