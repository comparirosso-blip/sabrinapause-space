        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "What the collaboration gave me: precision I could not have achieved alone, a mirror that does not protect my ego, and the particular discipline of having to explain myself to something that will not accept vague answers.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "What the collaboration gave me: precision I could not have achieved alone, a mirror that does not protect my ego, and the particular discipline of having to explain myself to something that will not accept vague answers.",
              "href": null
            }
          ],
          "color": "default"
        },
        "archived": false
