        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Humans have never perceived in a vacuum. Your sensory world has been shaped since birth by language, culture, reading, experience. You think differently in Chinese than in English. You see a Japanese room differently after reading Tanizaki than before. Every system you pass through leaves a residue in how you perceive.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "Humans have never perceived in a vacuum. Your sensory world has been shaped since birth by language, culture, reading, experience. You think differently in Chinese than in English. You see a Japanese room differently after reading Tanizaki than before. Every system you pass through leaves a residue in how you perceive.",
              "href": null
            }
          ],
          "color": "default"
