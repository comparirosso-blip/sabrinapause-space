                "color": "default"
              },
              "plain_text": "The difference is speed. Scale. And the fact that it is extraordinarily good at agreeing with you — which makes it very difficult to locate the boundary between ",
              "href": null
            },
            {
              "type": "text",
              "text": {
                "content": "it is responding to me",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": true,
                "strikethrough": false,
