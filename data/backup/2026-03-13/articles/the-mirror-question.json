        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Tanizaki wrote in ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "Tanizaki wrote in ",
              "href": null
            },
            {
              "type": "text",
              "text": {
                "content": "In Praise of Shadows",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": true,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "In Praise of Shadows",
              "href": null
            },
            {
              "type": "text",
              "text": {
                "content": " that the darkness of Japanese interiors trains a particular mode of perception. Move that same person into a brightly lit Western room, and something in that perception disappears. Space doesn't just reflect its inhabitants — it shapes what they are capable of feeling.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": " that the darkness of Japanese interiors trains a particular mode of perception. Move that same person into a brightly lit Western room, and something in that perception disappears. Space doesn't just reflect its inhabitants — it shapes what they are capable of feeling.",
              "href": null
            }
          ],
          "color": "default"
