            {
              "type": "text",
              "text": {
                "content": "I spent nine years as a diplomat. Which means I spent nine years watching how cultures encode what they dare not say out loud — into space, into ritual, into silence and distance.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "I spent nine years as a diplomat. Which means I spent nine years watching how cultures encode what they dare not say out loud — into space, into ritual, into silence and distance.",
              "href": null
            }
          ],
          "color": "default"
        },
