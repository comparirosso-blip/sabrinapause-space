        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "AI did not make things easier. It made things ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "AI did not make things easier. It made things ",
              "href": null
            },
            {
              "type": "text",
              "text": {
                "content": "clearer",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": true,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "clearer",
              "href": null
            },
            {
              "type": "text",
              "text": {
                "content": ". And clarity, for a human, is often harder to bear than confusion—because once you can see exactly where your thinking breaks down, you cannot pretend otherwise.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": ". And clarity, for a human, is often harder to bear than confusion—because once you can see exactly where your thinking breaks down, you cannot pretend otherwise.",
              "href": null
            }
          ],
          "color": "default"
        },
        "archived": false
