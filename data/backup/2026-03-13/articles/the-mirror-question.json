        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "It doesn't only reflect what you already have. It amplifies, recombines, fills in the gaps in your thinking. When you look at what it gives back to you, you can no longer be certain: is that your reflection? A edited version of you? Or someone who never existed before, but now suddenly does?",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "It doesn't only reflect what you already have. It amplifies, recombines, fills in the gaps in your thinking. When you look at what it gives back to you, you can no longer be certain: is that your reflection? A edited version of you? Or someone who never existed before, but now suddenly does?",
              "href": null
            }
          ],
          "color": "default"
        },
        "archived": false
